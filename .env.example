# Claude Chat Mobile —— 环境变量模板。各项说明见下方注释；部署见 docs/deployment.md、安全模型见 README「安全模型」。
# AUTH_TOKEN、WORK_DIR 留空也能跑（分别 fallback 到仅绑 127.0.0.1、默认 $HOME），
# 但通常需要按自己情况显式设置——对外暴露必填 AUTH_TOKEN，真正想用 claude 打开的项目目录需要填 WORK_DIR；其余都有合理默认值。

# ===== 鉴权（核心安全不变量）=====
# 未设=仅绑 127.0.0.1（无法公网暴露）。对外服务必填，openssl rand -hex 32 生成。
AUTH_TOKEN=

# ===== Cloudflare Access 双因子（可选）=====
# 三项全设才启用公网 2FA；任一缺失则整层关闭、回退纯 AUTH_TOKEN。配置见 docs/deployment.md「2. Access」。
CF_ACCESS_HOSTNAME=
CF_ACCESS_TEAM=
CF_ACCESS_AUD=

# ===== Anthropic 凭据/网关/模型：不在此配置 =====
# web 端继承启动 shell 环境，.env 里的 ANTHROPIC_* 启动期一律剥除（如需自定义，启动前于
# shell export）。见 README「安全模型」。

# ===== 运行时 =====
PORT=3000

# CCM 控制面数据目录（会话指针、设备信任、审批、审计、推送与缓存）。
# 留空兼容仓库内 ./data；常驻部署建议使用仓库外绝对路径并把目录权限设为 0700。
# macOS 示例：/Users/you/Library/Application Support/claude-chat-mobile/data
CCM_DATA_DIR=

# claude 工作目录，默认 $HOME；公网常驻部署应固定到具体项目（见 README「安全模型」）。
WORK_DIR=

# 多仓库切换：推荐 WORK_DIRS_FILE=workdirs.json（JSON 数组，支持热加载免重启）；或 WORK_DIRS 逗号分隔（无热加载）。
# 数组条目支持两种形态：字符串路径，或 {"path":"/abs/dir","sessionLimit":10}（sessionLimit=该区历史会话默认显示条数，缺省 6，上限 50）。
WORK_DIRS_FILE=
WORK_DIRS=

# agent 无输出超此时长判挂死并中断（等审批不计）。默认 10 分钟。
IDLE_TIMEOUT_MS=600000
# 完全空闲（无在途轮/后台任务/挂起审批提问）的 web 实例回收子进程。默认 30 分钟；0 = 禁用。
# 会话 transcript 仍在，再发送或切换回来会 resume 续接。与 IDLE_TIMEOUT_MS 正交。
INSTANCE_IDLE_RECLAIM_MS=1800000

# 工具权限确认/追问悬置无人处理时的自动到期时长，到期 fail-closed 自动拒绝并释放悬置。默认 30 分钟。
APPROVAL_TTL_MS=1800000

# 同一会话同类通知（审批/追问/完成）之间的最小推送间隔，防止连续触发时推送刷屏。默认 1 分钟。
NOTIFY_THROTTLE_MS=60000

# 删除会话前的 transcript 静默期：文件在此窗口内仍被修改过，判定可能有终端 CLI 进程正在写、拒绝删除。默认 5 分钟。
SESSION_DELETE_QUIET_MS=300000

# claude 可执行文件路径，默认 `which claude`。
CLAUDE_BIN=

# 设 1 输出 claude 子进程 stderr。
LOG_STDERR=
# 设 1 记录四跳内容摘要（脱敏、截断 1500 字符）。
LOG_INTERACTIONS=

# 设 1 开启开发者模式：齿轮面板出现「重启服务」按钮（dogfooding 改代码/.env 后一键 kickstart 常驻 server）。
# 生产对外部署应留空——防误触重启对外服务。仅在常驻部署（LaunchAgent/systemd KeepAlive）下有意义：优雅退出后自动拉起。
DEV_MODE=
# 设 1（诊断）打印每条原始 SDK 消息骨架到 stdout，排查后台任务通知/未映射消息类型。
DEBUG_SDK_MESSAGES=

# ===== Web Push（可选）=====
# 三项全设才启用；任一缺失则推送优雅缺席。私钥勿提交 git。
# 生成：node -e "import('web-push').then(m=>console.log(JSON.stringify(m.default.generateVAPIDKeys(),null,2)))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ===== ntfy（可选：更可靠的移动端通知，②）=====
# server 端一行 POST，绕过 iOS「添加到主屏幕」与局域网 http 的 Web Push 限制；没配则优雅缺席。
# 手机装 ntfy app 订阅 NTFY_TOPIC 即可收锁屏/息屏通知。
# ⚠️ 推送 body 已最小化（不含命令/问题正文），但 title 会带 cwd 尾段、明文经第三方 →
#    建议自托管 ntfy（NTFY_URL 指向自己的实例）或用私密 topic + NTFY_TOKEN，勿用公共 ntfy.sh 裸 topic。
NTFY_URL=
NTFY_TOPIC=
NTFY_TOKEN=

# 深链绝对 URL（点通知回到触发它的会话），公网域名如 https://ccm.example.com。
# 留空则回退 CF_ACCESS_HOSTNAME；再无则通知不带点击深链（仍正常送达）。
PUBLIC_URL=

# ===== Web 状态栏 =====
# 开箱即用；设 off 关闭（无 UI 痕迹）。
WEB_STATUSLINE=

# CLI statusline bridge 须先显式运行 `npm run statusline:install`，不会随 npm install / server 启动自动安装。
# 设 off 仅让 server 回滚为 SDK-only 状态栏，不卸载 CLI wrapper；改后须重启常驻 server。
CLI_STATUSLINE_BRIDGE=

# CLI statusline 快照目录；留空使用 ~/.claude/ccm/statusline-v1/snapshots。
# 自定义时请用绝对路径，并让启动 claude CLI 与 server 的环境都拿到同一个值；改后重开 CLI、重启 server。
CLI_STATUSLINE_DIR=
