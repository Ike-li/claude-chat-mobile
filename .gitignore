# 依赖
/node_modules/

# 环境变量与密钥（绝不提交）
# 覆盖 .env / .env.local / .env.production / .env.*.local 等；仅放行模板 .env.example
.env
.env.*
!.env.example
workdirs.json

# 运行时状态（ADR-005：会话元数据，本地生成）
/data/

# 上传附件落盘区（E17/ADR-013：本仓库被当 WORK_DIR 测试时会出现于此）
.ccm-uploads/

# Claude Code 会话产物（plan、skill 历史等，非项目资产）
/.claude/

# 常驻 worktree（promo/gh-pages 等分支的仓内检出位，便于 IDE 同窗查看；点目录 ESLint 默认不扫）
/.worktrees/

# 日志（*.log 文件 + 仓内 logs 目录/文件，防非 .log 后缀落盘被误加）
*.log
npm-debug.log*
/logs
/logs/**

# 系统/编辑器
.DS_Store
.vscode/
.idea/

.reasonix
.codegraph
reasonix.toml

# 测试/E2E 视觉回归测试临时截图
/public/test-snapshots/
/playwright-report/
/test-results/

.github/copilot-instructions.md
.codex/config.toml
.bug-hunter/
.agents/
.codex/