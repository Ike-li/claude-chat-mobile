{
  "name": "claude-chat-mobile",
  "version": "1.2.1",
  "description": "Mobile chat UI that bridges your local claude CLI to your phone — terminal-equivalent agent access (resume, streaming output, on-device tool approvals).",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-only",
  "author": "Ike-li (https://github.com/Ike-li)",
  "homepage": "https://github.com/Ike-li/claude-chat-mobile#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ike-li/claude-chat-mobile.git"
  },
  "bugs": {
    "url": "https://github.com/Ike-li/claude-chat-mobile/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent-sdk",
    "mobile",
    "pwa",
    "websocket",
    "self-hosted",
    "remote-access",
    "chat-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "setup": "node scripts/setup.js",
    "statusline:status": "node scripts/statusline-bridge-setup.js status",
    "statusline:install": "node scripts/statusline-bridge-setup.js install",
    "statusline:uninstall": "node scripts/statusline-bridge-setup.js uninstall",
    "dev": "node --watch server.js",
    "check": "eslint . && node scripts/doc-consistency.js && node scripts/check-visual-mock-registry.js && node scripts/check-playwright-forbidden-patterns.js && npm run inventory:check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "inventory:update": "node scripts/repo-inventory.js --write",
    "inventory:check": "node scripts/repo-inventory.js --check",
    "test": "node --import ./tests/setup/preload-env.mjs --test --test-force-exit tests/unit/*.test.mjs tests/integration/*.test.mjs",
    "test:unit": "node --import ./tests/setup/preload-env.mjs --test tests/unit/*.test.mjs",
    "test:integration": "node --import ./tests/setup/preload-env.mjs --test --test-force-exit tests/integration/*.test.mjs",
    "test:coverage": "node --import ./tests/setup/preload-env.mjs --experimental-test-coverage --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "test:visual": "npm run test:e2e",
    "test:playwright": "npm run test:e2e",
    "test:playwright:p0": "playwright test tests/e2e/p0",
    "test:smoke": "node tests/smoke/runner.js",
    "contract:check": "node scripts/contract-check.js",
    "preview:landing": "python3 -m http.server -d docs 8000"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.201",
    "compression": "^1.8.1",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "jose": "^6.2.3",
    "socket.io": "^4.8.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gifenc": "^1.0.3",
    "globals": "^17.7.0",
    "pngjs": "^7.0.0",
    "socket.io-client": "^4.8.3"
  }
}
